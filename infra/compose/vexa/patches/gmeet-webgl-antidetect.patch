+    const GL_SPOOF: Record<number, string> = {
+      37445: "Google Inc. (Intel)",
+      37446:
+        "ANGLE (Intel, Mesa Intel(R) UHD Graphics (CML GT2), OpenGL 4.6 (Core Profile) Mesa 23.2.1)",
+    };
+    for (const proto of [
+      (self as any).WebGLRenderingContext?.prototype,
+      (self as any).WebGL2RenderingContext?.prototype,
+    ]) {
+      if (!proto) continue;
+      const orig = proto.getParameter;
+      proto.getParameter = function (param: number) {
+        if (param in GL_SPOOF) return GL_SPOOF[param];
+        return orig.call(this, param);
+      };
+      // keep toString native-looking so the patch itself isn't an obvious tell
+      try {
