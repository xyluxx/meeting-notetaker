# Vexa environment (copy to the pinned Vexa checkout root as .env).
# Pinned to Vexa 0.10.6.3.14 / commit c0614ca7f9af31440c36792059b1dbc9a2f645c6.
# See infra/compose/vexa/README.md for the full bring-up.

# --- Transcription: LOCAL CPU (data stays on-box) ---
# The CPU transcription worker (docker-compose.cpu.yml) aliases itself as `transcription-service`
# on the shared external `vexa-network`. No hosted token needed.
TRANSCRIPTION_SERVICE_URL=http://transcription-service/v1/audio/transcriptions
TRANSCRIPTION_SERVICE_TOKEN=local
MODEL_SIZE=tiny
CPU_THREADS=0

# --- Ports (remapped: MinIO avoids the existing rosa-minio on 9000/9001) ---
API_GATEWAY_HOST_PORT=8056
ADMIN_API_PORT=8057
RUNTIME_API_PORT=8090
AGENT_API_PORT=8100
CALENDAR_SERVICE_PORT=8050
DASHBOARD_HOST_PORT=3001
POSTGRES_HOST_PORT=5458
MCP_HOST_PORT=18888
MINIO_HOST_PORT=9200
MINIO_CONSOLE_HOST_PORT=9201

# --- Admin (CHANGE THIS before first run) ---
ADMIN_TOKEN=change-me-strong-admin-token

# --- Images: pull prebuilt from DockerHub (no local build for the core stack) ---
IMAGE_TAG=latest
BROWSER_IMAGE=vexaai/vexa-bot:latest

# --- Embedded Postgres (Vexa's own; separate from our app DB) ---
DB_NAME=vexa
DB_USER=postgres
DB_PASSWORD=postgres

# --- Embedded MinIO (Vexa stores the .wav here; we copy it into our store in M7) ---
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vexa-access-key
MINIO_SECRET_KEY=vexa-secret-key
MINIO_BUCKET=vexa
MINIO_SECURE=false
