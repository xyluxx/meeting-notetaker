{
  "name": "personal-meeting-notetaker",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted meeting recorder + AI dashboard (Google Meet)",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "db:generate": "pnpm --filter @pmn/db generate",
    "db:migrate": "pnpm --filter @pmn/db migrate",
    "db:push": "pnpm --filter @pmn/db push",
    "db:studio": "pnpm --filter @pmn/db studio",
    "infra:up": "node scripts/compose.mjs up",
    "infra:down": "node scripts/compose.mjs down",
    "infra:logs": "node scripts/compose.mjs logs",
    "infra:ps": "node scripts/compose.mjs ps",
    "doctor": "node scripts/doctor.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  }
}
