# ─────────────────────────────────────────────────────────────────────────────
# Personal Meeting NoteTaker — environment template.
# Copy to `.env` (git-ignored) and fill in. `node scripts/doctor.mjs` checks required vars.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
OWNER_EMAIL=you@example.com

# ── Host port mappings (dev infra) ───────────────────────────────────────────
# Override if 5432/6379/8333 are taken by other local containers/services.
# Keep these in sync with the *_URL/ENDPOINT values below.
PG_HOST_PORT=5432
REDIS_HOST_PORT=6379
S3_HOST_PORT=8333

# ── Database (Postgres) ──────────────────────────────────────────────────────
POSTGRES_USER=pmn
POSTGRES_PASSWORD=pmn
POSTGRES_DB=pmn
# Host-side (running scripts on Windows against the compose DB):
DATABASE_URL=postgres://pmn:pmn@localhost:5432/pmn
# In-cluster value used by web/worker containers is set in compose (host = postgres).

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object storage (S3-compatible: SeaweedFS in dev, Garage/S3 in prod) ───────
S3_ENDPOINT=http://localhost:8333
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=pmn-access-key
S3_SECRET_ACCESS_KEY=pmn-secret-key
S3_BUCKET=recordings
S3_FORCE_PATH_STYLE=true

# ── Auth (Better Auth) ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32   (or: node -e "console.log(crypto.randomBytes(32).toString('hex'))")
BETTER_AUTH_SECRET=change-me-32-byte-hex
BETTER_AUTH_URL=https://localhost

# ── Encryption (envelope key for secrets at rest: CalDAV passwords, Vexa key) ─
# 32-byte hex. Generate: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
# Rotating requires the versioned-key scheme; never lose this.
MASTER_ENCRYPTION_KEY=change-me-32-byte-hex

# ── App URLs ─────────────────────────────────────────────────────────────────
APP_URL=https://localhost
NEXT_PUBLIC_APP_URL=https://localhost

# ── Calendar sync mode ───────────────────────────────────────────────────────
# Calendars are ingested via manual Meet-link paste + iCal/ICS subscription URL + CalDAV.
# No Google OAuth. iCal/ICS + CalDAV are polled on an interval.
CALENDAR_POLL_MINUTES=5

# ── Vexa (self-hosted meeting engine) ────────────────────────────────────────
# Vexa joins Meet + records audio + local Whisper transcription. We drive it over REST/WS.
# Gateway (user API) and admin API run in Vexa's own compose project on the shared network.
VEXA_BASE_URL=http://localhost:8056
VEXA_WS_URL=ws://localhost:8056/ws
VEXA_ADMIN_URL=http://localhost:8057
# Admin token gates user/key provisioning (set in Vexa's own .env; change off the default).
VEXA_ADMIN_TOKEN=change-me
# User API key minted once via the admin API; in the app it is stored AES-GCM-encrypted in settings.
# This env var is only a bootstrap/dev convenience.
VEXA_API_KEY=
# Local CPU Whisper model for dev (tiny|base). Larger/GPU on the VPS.
VEXA_WHISPER_MODEL=tiny
BOT_DISPLAY_NAME_DEFAULT=NoteTaker

# ── OpenRouter (AI summaries) ────────────────────────────────────────────────
# Can also be set per-owner in Settings; this is the bootstrap default.
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-haiku-4-5

# ── MCP server (read-mostly access for your AI agent) ────────────────────────
# Authenticate with a scoped API key minted in Settings → API & MCP.
MCP_PORT=8848
MCP_HOST=0.0.0.0

# ── Reverse proxy (Caddy) ────────────────────────────────────────────────────
# Dev: CADDY_TLS_MODE=internal -> self-signed local CA. VPS: set real domains + an ACME email
# (CADDY_TLS_MODE=you@example.com) so Caddy provisions Let's Encrypt certs automatically.
CADDY_DOMAIN=localhost
CADDY_MCP_DOMAIN=mcp.localhost
CADDY_TLS_MODE=internal
